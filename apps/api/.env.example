# EcoAware API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ─── Server ──────────────────────────────────────────────────────────────────

# Port to run the API server on (default: 3001)
PORT=3001

# Node environment: development | production | test
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────

# LibSQL/SQLite connection URL
# Local development: file:./carbon.db
# Turso cloud: libsql://<db-name>-<org>.turso.io
DATABASE_URL=file:./carbon.db

# Turso auth token (required for cloud deployments, leave empty for local SQLite)
DATABASE_AUTH_TOKEN=

# ─── Authentication ────────────────────────────────────────────────────────────

# JWT secret for access tokens (15-minute lifetime)
# IMPORTANT: In production, generate a cryptographically random 256-bit secret:
#   openssl rand -hex 32
JWT_SECRET=change-me-in-production

# JWT secret for refresh tokens (7-day lifetime)
# IMPORTANT: Must be different from JWT_SECRET
#   openssl rand -hex 32
JWT_REFRESH_SECRET=change-me-refresh-in-production

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins
# CORS_ORIGINS=https://ecoaware.vercel.app,http://localhost:5173
